<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF111411"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Header -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/permissions_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permissions Required"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/permissions_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CODE-IDE needs storage access to read and write project files"
            android:textColor="#FF9CA3AF"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <!-- Storage Permission Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_permission_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/permission_storage_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Storage Access"
                        android:textColor="#FFFFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Read and write project files on your device"
                        android:textColor="#FF9CA3AF"
                        android:textSize="12sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/permission_storage_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not Granted"
                    android:textColor="@color/status_error"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <Button
                android:id="@+id/permission_storage_grant_btn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Grant Permission"
                android:textAllCaps="false"
                android:backgroundTint="#FF4CAF50"
                android:textColor="#FFFFFFFF" />

        </LinearLayout>

        <!-- Install Packages Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_permission_card"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:layout_marginEnd="12dp"
                    android:alpha="0.5" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Install Packages"
                        android:textColor="#FFFFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Optional: Install APKs directly from the IDE"
                        android:textColor="#FF9CA3AF"
                        android:textSize="12sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optional"
                    android:textColor="#FFFFC107"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Continue Button -->
        <Button
            android:id="@+id/permissions_continue_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Continue"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:backgroundTint="#FF4CAF50"
            android:textColor="#FFFFFFFF"
            android:layout_marginBottom="16dp"
            android:alpha="0.5"
            android:enabled="false" />

        <!-- Skip Text -->
        <TextView
            android:id="@+id/permissions_skip_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You can grant permissions later in Settings"
            android:textColor="#FF6B7280"
            android:textSize="12sp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>
