<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/tab_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/tab_padding_horizontal"
    android:paddingEnd="@dimen/tab_padding_horizontal"
    android:paddingTop="@dimen/tab_padding_vertical"
    android:paddingBottom="@dimen/tab_padding_vertical"
    android:background="?attr/selectableItemBackground"
    android:minWidth="@dimen/tab_min_width"
    android:maxWidth="@dimen/tab_max_width">

    <!-- File Icon -->
    <ImageView
        android:id="@+id/tab_icon"
        android:layout_width="@dimen/tab_icon_size"
        android:layout_height="@dimen/tab_icon_size"
        android:layout_marginEnd="@dimen/spacing_xs" />

    <!-- File Name -->
    <TextView
        android:id="@+id/tab_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="@dimen/tab_text_size"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Dirty Indicator -->
    <View
        android:id="@+id/tab_dirty"
        android:layout_width="@dimen/tab_dirty_size"
        android:layout_height="@dimen/tab_dirty_size"
        android:layout_marginStart="@dimen/spacing_xs"
        android:background="@drawable/bg_dirty_indicator"
        android:visibility="gone" />

    <!-- Close Button -->
    <ImageView
        android:id="@+id/tab_close"
        android:layout_width="@dimen/tab_close_size"
        android:layout_height="@dimen/tab_close_size"
        android:layout_marginStart="@dimen/spacing_xs"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:alpha="0.4"
        android:visibility="gone" />

</LinearLayout>
