<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crash Report"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="@color/status_error"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Error Message -->
    <TextView
        android:id="@+id/crash_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp"
        android:lineSpacingMultiplier="1.2" />

    <!-- Loading -->
    <TextView
        android:id="@+id/crash_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading crash log..."
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorPrimary"
        android:visibility="visible"
        android:layout_marginBottom="8dp" />

    <!-- Log Container -->
    <ScrollView
        android:id="@+id/crash_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/colorSurfaceContainerLow"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/crash_log_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurface"
            android:typeface="monospace"
            android:lineSpacingMultiplier="1.3"
            android:textIsSelectable="true"
            android:padding="8dp" />

    </ScrollView>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crash_copy_btn"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Copy Log"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crash_restart_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Restart App"
            android:textAllCaps="false"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
