<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/drawer_header_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/drawer_item_padding"
    android:paddingEnd="@dimen/spacing_sm"
    android:background="@color/drawer_header_background"
    android:elevation="0dp">

    <!-- Project Icon -->
    <ImageView
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:src="@android:drawable/ic_menu_agenda"
        android:alpha="0.7"
        android:layout_marginEnd="@dimen/spacing_sm" />

    <!-- Project Name -->
    <TextView
        android:id="@+id/drawer_project_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/project_name"
        android:textColor="@color/drawer_item_text"
        android:textSize="@dimen/drawer_item_text_size"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Close Drawer Button -->
    <ImageButton
        android:id="@+id/drawer_close_btn"
        android:layout_width="@dimen/icon_size_large"
        android:layout_height="@dimen/icon_size_large"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/drawer_close"
        android:alpha="0.5" />

</LinearLayout>
